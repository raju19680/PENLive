{
  "$schema": "https://schema.tauri.app/config/2.0",
  "productName": "PENLIVE",
  "version": "1.0.0",
  "identifier": "com.penlive.app",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "PENLIVE - Er. Raju Kumawat",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "theme": "Light"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: https://*; media-src 'self' blob: stream:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Er. Raju Kumawat",
    "copyright": "Copyright (c) 2026 Er. Raju Kumawat. All rights reserved.",
    "category": "Education",
    "shortDescription": "Lightweight Desktop Writing & Recording App",
    "longDescription": "PENLIVE is a lightweight desktop application with writing tools, screen recording, webcam, microphone support, smart board, and Epic Pen-style overlay features.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {}
}
